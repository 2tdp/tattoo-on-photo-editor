<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/im_splash_1"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_84sdp"
        android:scaleType="fitCenter"
        android:src="@drawable/im_splash_2"
        app:layout_constraintTop_toBottomOf="@id/iv" />

    <com.tattoo.tattoomaker.on.myphoto.viewcustom.CustomLoadingSplash
        android:id="@+id/vLoading"
        android:layout_width="0dp"
        android:layout_height="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_20sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent=".65" />

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/solway_regular"
        android:layout_marginBottom="@dimen/_10sdp"
        android:text="@string/loading"
        android:textColor="@color/black"
        android:textSize="@dimen/_13ssp"
        app:layout_constraintBottom_toTopOf="@id/vLoading"
        app:layout_constraintEnd_toEndOf="@id/vLoading"
        app:layout_constraintStart_toStartOf="@id/vLoading" />
</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/black_65"
    android:paddingVertical="@dimen/_10sdp">

    <FrameLayout
        android:id="@+id/frColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/vColor"
            android:visibility="gone"
            layout="@layout/layout_color" />
    </FrameLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivNone"
        android:layout_width="@dimen/_20sdp"
        android:layout_height="@dimen/_34sdp"
        android:layout_marginStart="@dimen/_5sdp"
        android:src="@drawable/ic_none_item"
        android:layout_marginTop="@dimen/_10sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/frColor" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvTattoos"
        android:layout_width="0dp"
        android:layout_height="@dimen/_34sdp"
        android:layout_marginStart="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_10sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivNone"
        app:layout_constraintTop_toBottomOf="@id/frColor" />
</androidx.constraintlayout.widget.ConstraintLayout>